{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "secrets": [
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "MONTHLY_PRICE_ID",
        "SUCCESS_URL",
        "CANCEL_URL",
        "PORTAL_RETURN_URL"
      ],
      "disallowLegacyRuntimeConfig": true,
      "endpoints": {
        "stripeWebhook": {
          "region": "us-central1",
          "cors": false,
          "rawBody": true
        }
      }
    }
  ]
}
